class Solution {
    int countStrings(int n) {
        
        if (n == 1) return 2;
        
        int endWithZero = 1;  // dp[1][0]
        int endWithOne = 1;   // dp[1][1]
        
        for (int i = 2; i <= n; i++) {
            int newZero = endWithZero + endWithOne;
            int newOne = endWithZero;
            
            endWithZero = newZero;
            endWithOne = newOne;
        }
        
        return endWithZero + endWithOne;
    }
}
