import java.util.*;

class Solution {
    public int countSubarrays(int[] arr) {
        int n = arr.length;
        Stack<Integer> stack = new Stack<>();
        long count = 0;

        for (int i = n - 1; i >= 0; i--) {
            
            // Remove elements greater than or equal to current
            while (!stack.isEmpty() && arr[stack.peek()] >= arr[i]) {
                stack.pop();
            }
            
            if (stack.isEmpty()) {
                // Can extend till end
                count += (n - i);
            } else {
                // Can extend till next smaller element
                count += (stack.peek() - i);
            }
            
            stack.push(i);
        }
        
        return (int)count;
    }
}
