class Solution {
    String removeSpaces(String s) {
        char[] arr = s.toCharArray();
        int index = 0;

        for (int i = 0; i < arr.length; i++) {
            if (arr[i] != ' ') {
                arr[index++] = arr[i];
            }
        }

        return new String(arr, 0, index);
    }
}
